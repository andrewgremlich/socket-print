{
	"name": "socket-print",
	"productName": "Provel Print",
	"description": "A CAD-type application that facilitates a faster turnaround time for amputees to receive 3D printed socket for a residual limb.",
	"version": "1.21.0",
	"type": "module",
	"author": {
		"name": "andrewgremlich"
	},
	"license": "MIT",
	"engines": {
		"node": ">=24"
	},
	"repository": {
		"url": "https://github.com/andrewgremlich/socket-print"
	},
	"scripts": {
		"dev": "npm run dev:web",
		"dev:web": "vite --config vite.config.ts",
		"build": "npm run test && npm run clean && vite build",
		"preview": "vite preview --config vite.config.ts",
		"prepare": "husky",
		"test": "vitest run src/ --config ./vite.config.ts",
		"test:watch": "vitest src/ --config ./vite.config.ts",
		"test:coverage": "vitest run --coverage src/",
		"check": "tsc --noEmit && biome check --write ./src",
		"clean": "rimraf ./dist ./.vite ./out ./dev-dist",
		"changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
		"knip": "knip"
	},
	"lint-staged": {
		"*.{js,ts,tsx}": [
			"npm run check"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/node": "^25.5.0",
		"@types/three": "^0.183.1",
		"@types/validator": "^13.15.10",
		"@vitest/coverage-v8": "^4.1.2",
		"browserslist": "^4.28.1",
		"conventional-changelog": "^7.2.0",
		"conventional-changelog-conventionalcommits": "^9.3.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.1",
		"knip": "^6.0.6",
		"lightningcss": "^1.32.0",
		"lint-staged": "^16.4.0",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.2",
		"vite": "^8.0.3",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"crc-32": "^1.2.2",
		"dexie": "^4.4.1",
		"hotkeys-js": "^4.0.2",
		"lucide": "1.7.0",
		"mathjs": "^15.1.1",
		"three": "^0.183.2",
		"three-mesh-bvh": "^0.9.9",
		"validator": "^13.15.26"
	}
}
