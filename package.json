{
	"name": "socket-print",
	"productName": "Provel Print",
	"description": "A CAD-type application that facilitates a faster turnaround time for amputees to receive 3D printed socket for a residual limb.",
	"version": "v4.8.2-alpha",
	"main": ".vite/build/main.js",
	"type": "module",
	"author": {
		"name": "andrewgremlich",
		"email": "engineering@gremlich.xyz"
	},
	"license": "MIT",
	"repository": {
		"url": "https://github.com/andrewgremlich/socket-print"
	},
	"scripts": {
		"dev": "npm run dev:web",
		"dev:web": "vite --config vite.config.ts",
		"build": "vite build --config vite.config.ts",
		"preview": "vite preview",
		"prepare": "husky",
		"test": "vitest src/ --config ./vite.config.ts",
		"type-check": "tsc --noEmit",
		"check": "biome check --write ./src",
		"clean": "rimraf ./dist ./.vite ./out ./dev-dist"
	},
	"lint-staged": {
		"*.{js,ts,tsx}": [
			"npm run check"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@tauri-apps/cli": "^2.3.1",
		"@types/node": "^22.13.10",
		"@types/three": "^0.174.0",
		"browserslist": "^4.24.4",
		"husky": "^9.1.7",
		"lightningcss": "^1.29.3",
		"lint-staged": "^15.5.0",
		"rimraf": "^6.0.1",
		"ts-node": "^10.9.2",
		"typescript": "^5.8.2",
		"vite": "^6.2.1",
		"vite-plugin-top-level-await": "^1.5.0",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.0.8"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.3.0",
		"@tauri-apps/plugin-dialog": "^2.2.0",
		"crc-32": "^1.2.2",
		"dexie": "^4.0.11",
		"mathjs": "^14.3.1",
		"p-throttle": "^7.0.0",
		"three": "^0.174.0",
		"three-csg-ts": "^3.2.0",
		"three-mesh-bvh": "^0.9.0",
		"vite-plugin-pwa": "^0.21.1"
	}
}
